<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<%- partial('partial/head') %>
<body class="cyber-body">
  <!-- 載入遮罩 -->
  <div class="page-loader">
    <div class="loader-content">
      <div class="loader-glitch" data-text="LOADING">LOADING</div>
      <div class="loader-bar">
        <div class="loader-progress"></div>
      </div>
      <div class="loader-percent">0%</div>
    </div>
  </div>

  <!-- 背景效果層 -->
  <div class="cyber-bg">
    <div class="cyber-grid"></div>
    <div class="cyber-scanline"></div>
    <canvas id="particle-canvas"></canvas>
  </div>

  <%- partial('partial/header') %>

  <main class="site-main">
    <div class="container">
      <!-- Hero 區域 - Cyberpunk 2077 風格動畫 -->
      <section class="hero-section" data-animate="hero">
        <!-- 主標題：站點名稱（依 config.title 動態產生 glitch 分層） -->
        <div id="cyber-logo" class="cyber-logo">
          <div class="logo-main">
            <!-- 青色層 (主層) -->
            <div class="logo-layer logo-cyan">
              <% for (const ch of Array.from(config.title || 'AI NEWS')) { %>
                <span class="logo-char"><%= ch === ' ' ? '\u00A0' : ch %></span>
              <% } %>
            </div>
            <!-- 粉色層 (Glitch 層) -->
            <div class="logo-layer logo-pink" aria-hidden="true">
              <% for (const ch of Array.from(config.title || 'AI NEWS')) { %>
                <span class="logo-char"><%= ch === ' ' ? '\u00A0' : ch %></span>
              <% } %>
            </div>
          </div>

          <!-- 副標題：英文 slogan -->
          <div class="logo-sub">
            <div class="sub-bg"></div>
            <div class="sub-text sub-text-en">
              <% for (const ch of Array.from('AI NEWS DAILY')) { %>
                <span class="sub-char"><%= ch === ' ' ? '\u00A0' : ch %></span>
              <% } %>
            </div>
          </div>

          <!-- 裝飾元素 -->
          <div class="logo-decor">
            <span class="decor-line left"></span>
            <span class="decor-line right"></span>
            <span class="decor-dot dot-1"></span>
            <span class="decor-dot dot-2"></span>
          </div>
        </div>

        <!-- 描述文字 -->
        <p class="hero-desc">
          <span class="desc-bracket">[</span>
          <span class="desc-text"><%= config.description || config.subtitle || '每日自動彙整前沿 AI 資訊' %></span>
          <span class="desc-bracket">]</span>
        </p>

        <!-- 統計數據 -->
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number" data-count="<%= site.categories.length %>">0</span>
            <span class="stat-label">SOURCES</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-count="<%= site.posts.length %>">0</span>
            <span class="stat-label">ARTICLES</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-count="<%= new Date().getFullYear() %>">0</span>
            <span class="stat-label">YEAR</span>
          </div>
        </div>
      </section>

      <!-- 新聞分類卡片（依 site.categories 動態產生） -->
      <% if (site.categories && site.categories.length) { %>
      <section class="series-section" data-animate="cards">
        <div class="section-header">
          <div class="section-line"></div>
          <h2 class="section-title">
            <span class="title-icon">◆</span>
            新聞分類
            <span class="title-icon">◆</span>
          </h2>
          <div class="section-line"></div>
        </div>

        <div class="series-grid">
          <% site.categories.sort('name').forEach(function(cat) { %>
            <a href="<%- url_for(cat.path) %>" class="series-card">
              <div class="card-glow"></div>
              <div class="card-border"></div>
              <div class="card-content">
                <div class="card-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="4" width="18" height="16" rx="2"/>
                    <path d="M7 8h10M7 12h10M7 16h6"/>
                  </svg>
                </div>
                <h3 class="card-title"><%= cat.name %></h3>
                <p class="card-desc">瀏覽「<%= cat.name %>」分類下的全部 AI 資訊。</p>
                <div class="card-footer">
                  <div class="card-tag">
                    <span class="tag-dot"></span>
                    <%= cat.length %> 篇文章
                  </div>
                  <div class="card-arrow">
                    <span>進入</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="card-hologram"></div>
            </a>
          <% }); %>
        </div>
      </section>
      <% } %>

      <!-- 最新文章 -->
      <section class="recent-section" data-animate="posts">
        <div class="section-header">
          <div class="section-line"></div>
          <h2 class="section-title">
            <span class="title-icon">◆</span>
            最新文章
            <span class="title-icon">◆</span>
          </h2>
          <div class="section-line"></div>
        </div>

        <div class="posts-container">
          <% site.posts.sort('date', -1).slice(0, 15).forEach(function(post, index) { %>
            <article class="post-item" data-index="<%= index %>">
              <div class="post-index"><%= String(index + 1).padStart(2, '0') %></div>
              <a href="<%- url_for(post.path) %>" class="post-link">
                <div class="post-info">
                  <span class="post-category">
                    <% if (post.categories && post.categories.length) { %>
                      <%= post.categories.toArray()[0].name %>
                    <% } %>
                  </span>
                  <h3 class="post-title"><%= post.title %></h3>
                </div>
                <time class="post-date"><%= post.date.format('YYYY.MM.DD') %></time>
              </a>
              <div class="post-line"></div>
            </article>
          <% }); %>
        </div>

        <a href="<%- url_for('/archives/') %>" class="view-all-btn">
          <span class="btn-text">查看所有文章</span>
          <span class="btn-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
          <div class="btn-glow"></div>
        </a>
      </section>
    </div>
  </main>

  <!-- 側邊裝飾 -->
  <div class="side-decor left">
    <div class="decor-line"></div>
    <div class="decor-nodes">
      <span></span><span></span><span></span><span></span>
    </div>
  </div>
  <div class="side-decor right">
    <div class="decor-bars">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
  </div>

  <%- partial('partial/footer') %>
</body>
</html>
